# 실제 답변은 LLM 으로만 생성한다. 아래 중 하나를 PowerShell 에 입력한 뒤
# python app.py 를 실행해라. 설정이 없거나 API가 실패하면 자동 대체 답변 없이 오류만 반환한다.
#
# LLM_PROVIDER 만 정하면 api_base/모델 기본값이 자동으로 채워진다.
# 키만 넣으면 된다.

# ── 1) Google Gemini (무료 등급 넉넉, 한국어 좋음) ── 추천
#   https://aistudio.google.com/apikey 에서 무료 키 발급
#   $env:LLM_PROVIDER="gemini"
#   $env:LLM_API_KEY="발급받은_키"
#   (선택) $env:LLM_MODEL="gemini-2.5-flash"
#   (선택) $env:LLM_REASONING_EFFORT="none"

# ── 2) Groq (무료, 빠름) ──
#   https://console.groq.com/keys 에서 키 발급
#   $env:LLM_PROVIDER="groq"
#   $env:LLM_API_KEY="발급받은_키"

# ── 3) OpenRouter (무료 모델 일부) ──
#   $env:LLM_PROVIDER="openrouter"
#   $env:LLM_API_KEY="발급받은_키"
#   $env:LLM_MODEL="meta-llama/llama-3.3-70b-instruct:free"

# ── 4) 로컬 Ollama (키 불필요, 모델 설치 필요) ──
#   ollama pull exaone3.5:7.8b
#   $env:LLM_PROVIDER="ollama"
#   $env:LLM_MODEL="exaone3.5:7.8b"

# 공통 선택 옵션:
#   $env:LLM_TIMEOUT="45"
#   $env:LLM_TEMPERATURE="0.35"
#   $env:LLM_MAX_TOKENS="512"
